# Configuración del Puerto del Servidor
PORT=3000

# API Key de Google Gemini (Consíguela gratis en Google AI Studio o habilitando Gemini Developer API en Firebase Console)
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Credenciales de WhatsApp Business Cloud API (Consíguelas en developers.facebook.com)
WHATSAPP_ACCESS_TOKEN=tu_whatsapp_access_token_aqui
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id_aqui

# Token de verificación personalizado para enlazar el webhook en el panel de Meta (Eliges cualquier texto seguro)
WHATSAPP_VERIFY_TOKEN=dracotoken123
